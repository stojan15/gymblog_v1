@model gymblog1.Models.Post

@{
    ViewBag.Title = "Novi Post";
}

<h2>Kreiraj novi post</h2>

@using (Html.BeginForm("Create", "Post1", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        @Html.TextBoxFor(m => m.Title, new { @class = "form-control", placeholder = "Naslov" })
        @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.TextAreaFor(m => m.Content, new { @class = "form-control", placeholder = "Sadržaj" })
        @Html.ValidationMessageFor(m => m.Content, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        <label>Slika:</label>
        <input type="file" name="image" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Dodaj</button>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
