@model IEnumerable<gymblog1.Models.Post>

<div class="search-section">
    @using (Html.BeginForm("Index", "Post1", FormMethod.Get, new { @class = "search-form" }))
    {
        <input type="text" name="search" placeholder="Pretraži stavke (npr. Bench, Squat...)" />
        <select name="sort">
            <option value="">Sortiraj po datumu</option>
            <option value="likes">Najviše lajkova</option>
        </select>
        <button type="submit">OK</button>
    }
</div>
<div class="row">
    <!-- Glavni deo sa postovima (Levo) -->
    <div class="col-md-8">
        @* Ovde ide onaj kod za listanje postova koji smo ranije pisali *@
    </div>

    <!-- Sidebar sa parametrima (Desno) -->
</div>
<div style="display: flex; gap: 20px; align-items: stretch; width: 100%; margin-bottom: 30px;">

    <!-- LEVA STRANA: Prioriteti (Popunjava rupu) -->
    <div style="flex: 2; background: #111; border: 1px solid #333; border-radius: 15px; padding: 20px;">
        <h3 style="color: #d4ff00; font-weight: bold; border-bottom: 2px solid #d4ff00; padding-bottom: 10px;">
            DANAŠNJI PLAN TRENINGA
        </h3>
        <div style="margin-top: 20px; color: white;">
            <p style="font-size: 1.2rem;">💪 <strong>Fokus:</strong> Upper Body (Snaga)</p>
            <p>🍳 <strong>Sledeći obrok:</strong> Jaja i ovsene (Doručak)</p>

            <div style="background: #1a1a1a; padding: 15px; border-radius: 10px; margin-top: 30px; border-left: 5px solid #d4ff00;">
                <p style="margin: 0; color: #aaa; font-style: italic;">
                    "Moraš uneti onih 180g proteina danas da bi mišići rasli!"
                </p>
            </div>
        </div>
    </div>

    <!-- DESNA STRANA: Tvoj Dnevni Status -->
    <div style="flex: 1; min-width: 350px; background: #1a1a1a; border-radius: 15px; padding: 20px; border: 1px solid #333;">
        <h3 style="color: #d4ff00; text-align: center;">DNEVNI STATUS</h3>
        <hr style="border-color: #333;" />

        <p style="color: #888;">Cilj kalorija:</p>
        <h4 style="color: white; font-weight: bold;">2500 kcal</h4>

        <div style="margin-top: 20px;">
            <div style="display: flex; justify-content: space-between; color: white; font-size: 0.9rem;">
                <span>Protein:</span>
                <span>126g / 180g</span>
            </div>
            <div style="width: 100%; background: #333; height: 12px; border-radius: 6px; margin-top: 5px;">
                <div style="width: 70%; background: #d4ff00; height: 100%; border-radius: 6px;"></div>
            </div>
        </div>

        <div style="margin-top: 20px;">
            <div style="display: flex; justify-content: space-between; color: white; font-size: 0.9rem;">
                <span>Ugljeni hidrati:</span>
                <span>125g / 250g</span>
            </div>
            <div style="width: 100%; background: #333; height: 12px; border-radius: 6px; margin-top: 5px;">
                <div style="width: 50%; background: #00e5ff; height: 100%; border-radius: 6px;"></div>
            </div>
        </div>

        <p style="margin-top: 30px; color: #aaa; font-size: 0.8rem; text-align: center; font-style: italic;">
            "Ne odustaj, svaki trening se računa!"
        </p>
    </div>
</div>
<div class="posts-grid">
    @if (!Model.Any())
    {
        <div class="no-posts">
            <p>Trenutno nema objavljenih treninga. Budi prvi, <a href="@Url.Action("Create", "Post1")">objavi nešto!</a></p>
        </div>
    }
    else
    {
        foreach (var item in Model)
        {
            <div class="post-card">
                @if (!string.IsNullOrEmpty(item.ImagePath))
                {
                    <img src="@Url.Content(item.ImagePath)" alt="Gym Image" />
                }
                <div class="post-content">
                    <h2>@item.Title</h2>
                    <p>@item.Content.Substring(0, Math.Min(item.Content.Length, 100))...</p>
                    <div class="post-meta">
                        <span>❤️ @(item.Likes?.Count ?? 0)</span>
                        @Html.ActionLink("Pročitaj više", "Details", new { id = item.Id }, new { @class = "btn-details" })
                    </div>
                </div>
            </div>
        }
    }
</div>